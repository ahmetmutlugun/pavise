<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="description" content="Pavise security analysis report for {{ report.app_info.name }} ({{ report.app_info.identifier }}) — Grade {{ report.grade }}, Score {{ report.security_score }}/100.">
<meta name="robots" content="noindex, nofollow">
<title>Pavise Report — {{ report.app_info.name }} ({{ report.grade }})</title>
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{
  --bg:#0d1117;--surface:#161b22;--surface2:#1c2128;
  --border:#30363d;--border-inner:#21262d;
  --text-heading:#f0f6fc;--text-body:#c9d1d9;--text-dim:#8b949e;
  --accent:#58a6ff;
  --high:#f85149;--high-bg:#3d0f0f;--high-border:#6e1a1a;--high-subtle:#1a0a0a;
  --warn:#d29922;--warn-bg:#2d1f00;--warn-border:#5a3e00;--warn-subtle:#1a1400;
  --info:#58a6ff;--info-bg:#0d2045;--info-border:#1f4080;
  --secure:#3fb950;--secure-bg:#0d2c1a;--secure-border:#1a5c34;--secure-text:#7ee787;--secure-subtle:#0d1a12;
  --code-blue:#79c0ff;--code-orange:#f0883e;
  --mono:'SF Mono',Consolas,monospace;
  --sans:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;
}
body{font-family:var(--sans);background:var(--bg);color:var(--text-body);font-size:14px;line-height:1.5}
a{color:var(--accent);text-decoration:none}
.container{max-width:1100px;margin:0 auto;padding:0 24px}

/* Header */
.header{background:linear-gradient(135deg,var(--surface) 0%,var(--bg) 100%);border-bottom:1px solid var(--border);padding:32px 0}
.header-inner{display:flex;align-items:flex-start;justify-content:space-between;gap:24px}
.app-name{font-size:28px;font-weight:700;color:var(--text-heading);margin-bottom:6px}
.app-meta{color:var(--text-dim);font-size:13px;display:flex;flex-wrap:wrap;gap:12px}
.app-meta span{display:flex;align-items:center;gap:4px}
.pill{background:var(--surface2);border:1px solid var(--border);border-radius:12px;padding:2px 10px;font-size:12px;color:var(--text-dim)}

/* Score panel */
.score-panel{display:flex;flex-direction:column;align-items:center;background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:20px 28px;min-width:160px;flex-shrink:0}
.grade{font-size:56px;font-weight:800;line-height:1;margin-bottom:4px}
.grade-a{color:#3fb950}
.grade-b{color:#56d364}
.grade-c{color:#d29922}
.grade-d{color:#f0883e}
.grade-f{color:#dc2626}
.score-num{font-size:22px;font-weight:600;color:var(--text-heading)}
.score-num span{font-size:14px;color:var(--text-dim);font-weight:400}
.score-bar{width:100%;height:6px;background:var(--surface2);border-radius:3px;margin-top:10px;overflow:hidden}
.score-fill{height:100%;border-radius:3px;background:linear-gradient(90deg,var(--high),var(--warn),var(--secure))}

/* Stats bar */
.stats-bar{display:flex;gap:0;border:1px solid var(--border);border-radius:10px;overflow:hidden;margin:24px 0;background:var(--surface)}
.stat{flex:1;padding:16px 12px;text-align:center;border-right:1px solid var(--border)}
.stat:last-child{border-right:none}
.stat-val{display:block;font-size:24px;font-weight:700;line-height:1.1}
.stat-val.high{color:var(--high)}
.stat-val.warn{color:var(--warn)}
.stat-val.info{color:var(--info)}
.stat-val.ok{color:var(--secure)}
.stat-label{display:block;font-size:11px;color:var(--text-dim);text-transform:uppercase;letter-spacing:.06em;margin-top:3px}

/* Sections */
.section{margin-bottom:32px}
.section-title{font-size:16px;font-weight:600;color:var(--text-heading);padding:12px 16px;background:var(--surface);border:1px solid var(--border);border-bottom:none;border-radius:8px 8px 0 0;display:flex;align-items:center;gap:8px}
.section-title .count{background:var(--surface2);border:1px solid var(--border);border-radius:10px;padding:1px 8px;font-size:12px;color:var(--text-dim);font-weight:500}
.section-body{border:1px solid var(--border);border-radius:0 0 8px 8px;overflow:hidden}

/* App Info table */
.info-table{width:100%;border-collapse:collapse}
.info-table tr{border-bottom:1px solid var(--border-inner)}
.info-table tr:last-child{border-bottom:none}
.info-table th{width:200px;padding:10px 16px;text-align:left;font-weight:500;color:var(--text-dim);font-size:12px;text-transform:uppercase;letter-spacing:.04em;background:var(--surface)}
.info-table td{padding:10px 16px;color:var(--text-body)}

/* Binary protections */
.protections-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:0;background:var(--bg)}
.protection-item{display:flex;align-items:center;gap:12px;padding:12px 16px;border-bottom:1px solid var(--border-inner);border-right:1px solid var(--border-inner)}
.prot-icon{width:20px;height:20px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;flex-shrink:0}
.prot-icon.ok{background:#0d4429;color:var(--secure)}
.prot-icon.bad{background:var(--high-bg);color:var(--high)}
.prot-icon.warn{background:var(--warn-bg);color:var(--warn)}
.prot-name{font-size:13px;color:var(--text-body)}
.prot-desc{font-size:11px;color:var(--text-dim);margin-top:2px}

/* Findings */
.finding{padding:16px;border-bottom:1px solid var(--border-inner);background:var(--bg)}
.finding:last-child{border-bottom:none}
.finding-header{display:flex;align-items:flex-start;justify-content:space-between;gap:12px;margin-bottom:8px}
.finding-title{font-size:14px;font-weight:600;color:var(--text-heading)}
.finding-id{font-size:11px;color:var(--text-dim);font-family:var(--mono);white-space:nowrap}
.sev-badge{display:inline-flex;align-items:center;padding:2px 8px;border-radius:4px;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.04em;white-space:nowrap}
.sev-high{background:var(--high-bg);color:var(--high);border:1px solid var(--high-border)}
.sev-warn{background:var(--warn-bg);color:var(--warn);border:1px solid var(--warn-border)}
.sev-info{background:var(--info-bg);color:var(--info);border:1px solid var(--info-border)}
.sev-secure{background:var(--secure-bg);color:var(--secure);border:1px solid var(--secure-border)}
.finding-desc{font-size:13px;color:var(--text-dim);margin-bottom:8px}
.finding-evidence{background:var(--surface);border:1px solid var(--border);border-radius:6px;padding:8px 12px;font-family:var(--mono);font-size:12px;color:var(--code-blue);word-break:break-all;margin-bottom:8px}
.finding-remediation{display:flex;gap:8px;background:var(--secure-bg);border:1px solid var(--secure-border);border-radius:6px;padding:8px 12px}
.finding-remediation-label{font-size:11px;font-weight:600;color:var(--secure);text-transform:uppercase;letter-spacing:.04em;white-space:nowrap;margin-top:1px}
.finding-remediation-text{font-size:12px;color:var(--secure-text)}
.finding-meta{display:flex;flex-wrap:wrap;gap:6px;margin-top:8px}
.meta-tag{background:var(--surface2);border:1px solid var(--border);border-radius:4px;padding:1px 7px;font-size:11px;color:var(--text-dim);font-family:var(--mono)}

/* Secrets */
.secret-item{display:flex;align-items:flex-start;gap:12px;padding:12px 16px;border-bottom:1px solid var(--border-inner);background:var(--bg)}
.secret-item:last-child{border-bottom:none}
.secret-title{font-size:13px;font-weight:600;color:var(--text-heading);margin-bottom:2px}
.secret-path{font-size:11px;color:var(--text-dim);font-family:var(--mono);margin-bottom:4px}
.secret-value{background:var(--surface);border:1px solid var(--border);border-radius:4px;padding:4px 10px;font-family:var(--mono);font-size:12px;color:var(--code-orange);word-break:break-all}

/* Trackers */
.tracker-item{padding:12px 16px;border-bottom:1px solid var(--border-inner);background:var(--bg);display:flex;align-items:flex-start;justify-content:space-between;gap:12px}
.tracker-item:last-child{border-bottom:none}
.tracker-name{font-size:13px;font-weight:600;color:var(--text-heading)}
.tracker-evidence{font-size:11px;color:var(--text-dim);font-family:var(--mono);margin-top:2px}
.tracker-cats{display:flex;flex-wrap:wrap;gap:4px;margin-top:6px}
.tracker-cat{background:var(--surface2);border:1px solid var(--border);border-radius:10px;padding:1px 8px;font-size:11px;color:var(--text-dim)}

/* Domains */
.domain-list{padding:12px 16px;display:flex;flex-wrap:wrap;gap:8px;background:var(--bg)}
.domain-tag{background:var(--surface);border:1px solid var(--border);border-radius:4px;padding:3px 10px;font-family:var(--mono);font-size:12px;color:var(--code-blue)}
.email-tag{background:var(--surface);border:1px solid var(--border);border-radius:4px;padding:3px 10px;font-family:var(--mono);font-size:12px;color:var(--text-body)}

/* Firebase card */
.firebase-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));background:var(--bg)}
.firebase-item{padding:10px 16px;border-bottom:1px solid var(--border-inner);border-right:1px solid var(--border-inner)}
.firebase-key{font-size:11px;color:var(--text-dim);text-transform:uppercase;letter-spacing:.04em;margin-bottom:3px}
.firebase-val{font-family:var(--mono);font-size:12px;color:var(--code-blue);word-break:break-all}

/* Hashes */
.hashes{display:grid;grid-template-columns:auto 1fr;gap:4px 16px;padding:12px 16px;background:var(--bg)}
.hash-key{font-size:11px;color:var(--text-dim);text-transform:uppercase;letter-spacing:.04em;align-self:center}
.hash-val{font-family:var(--mono);font-size:12px;color:var(--text-dim);word-break:break-all}

/* Footer */
.footer{border-top:1px solid var(--border);padding:24px 0;margin-top:40px;color:var(--text-dim);font-size:12px;display:flex;justify-content:space-between;align-items:center}
.footer-logo{font-weight:700;color:var(--text-heading)}

/* Empty states */
.empty{padding:24px;text-align:center;color:var(--text-dim);font-size:13px;background:var(--bg)}

/* Collapsible framework section */
details summary{cursor:pointer;padding:10px 16px;background:var(--surface);border-bottom:1px solid var(--border-inner);color:var(--text-dim);font-size:12px;user-select:none;list-style:none}
details summary::-webkit-details-marker{display:none}
details summary::before{content:"▶ ";font-size:10px}
details[open] summary::before{content:"▼ "}

/* OWASP grid */
.owasp-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:1px;background:var(--border)}
.owasp-cell{padding:14px 12px;display:flex;flex-direction:column;gap:4px;background:var(--bg)}
.owasp-cell.ok{background:var(--secure-subtle)}
.owasp-cell.bad{background:var(--high-subtle)}
.owasp-code{font-size:15px;font-weight:700;font-family:var(--mono)}
.owasp-cell.ok .owasp-code{color:var(--secure)}
.owasp-cell.bad .owasp-code{color:var(--high)}
.owasp-label{font-size:11px;color:var(--text-dim);line-height:1.3}
.owasp-count{font-size:12px;font-weight:600}
.owasp-cell.ok .owasp-count{color:var(--secure)}
.owasp-cell.bad .owasp-count{color:var(--high)}

/* CVE table */
.cve-row-high{background:var(--high-subtle)}
.cve-row-warning{background:var(--warn-subtle)}

/* Baseline diff cards */
.diff-cards{display:flex;gap:0;border:1px solid var(--border);border-radius:10px;overflow:hidden;margin-bottom:24px;background:var(--surface)}
.diff-card{flex:1;padding:16px 12px;text-align:center;border-right:1px solid var(--border)}
.diff-card:last-child{border-right:none}
.diff-val{display:block;font-size:22px;font-weight:700;line-height:1.1}
.diff-label{display:block;font-size:11px;color:var(--text-dim);text-transform:uppercase;letter-spacing:.06em;margin-top:3px}
.diff-tags{display:flex;flex-wrap:wrap;gap:6px;padding:10px 16px;background:var(--bg)}
.diff-tag-new{background:var(--info-bg);border:1px solid var(--info-border);border-radius:4px;padding:2px 8px;font-size:11px;font-family:var(--mono);color:var(--info)}
.diff-tag-fixed{background:var(--secure-bg);border:1px solid var(--secure-border);border-radius:4px;padding:2px 8px;font-size:11px;font-family:var(--mono);color:var(--secure)}

/* Skip link */
.skip-link{position:absolute;top:-100%;left:0;background:var(--accent);color:var(--bg);padding:8px 16px;z-index:100;font-size:13px;font-weight:600;text-decoration:none;border-radius:0 0 4px 0}
.skip-link:focus{top:0;outline:none}

/* Utility colors */
.clr-ok{color:var(--secure)}
.clr-bad{color:var(--high)}
.clr-dim{color:var(--text-dim)}

/* Responsive */
@media(max-width:768px){
  .header-inner{flex-direction:column}
  .score-panel{flex-direction:row;justify-content:space-between;align-items:center;min-width:unset;width:100%;padding:16px}
  .owasp-grid{grid-template-columns:repeat(2,1fr)}
  .stats-bar{flex-wrap:wrap}
  .stat{min-width:calc(33.33% - 2px)}
  .section-body{overflow-x:auto}
  .info-table th{width:140px}
  .diff-cards{flex-wrap:wrap}
  .diff-card{flex:1 1 45%;min-width:100px}
  .protections-grid{grid-template-columns:1fr}
  .firebase-grid{grid-template-columns:1fr}
  .container{padding:0 16px}
}
@media(max-width:480px){
  .owasp-grid{grid-template-columns:1fr 1fr}
  .grade{font-size:40px}
  .score-num{font-size:16px}
  .stats-bar .stat{min-width:calc(50% - 2px)}
  .score-panel{flex-direction:column;align-items:flex-start}
}
</style>
</head>
<body>
<a href="#main-content" class="skip-link">Skip to main content</a>

<div class="header">
<div class="container">
<div class="header-inner">
  <div>
    <div class="app-name">{{ report.app_info.name }}</div>
    <div class="app-meta">
      <span>{{ report.app_info.identifier }}</span>
      <span class="pill">v{{ report.app_info.version }} ({{ report.app_info.build }})</span>
      <span class="pill">iOS {{ report.app_info.min_os_version }}+</span>
      <span class="pill">{{ report.app_info.app_type }}</span>
      {% if report.app_info.supported_platforms %}
      <span class="pill">{{ report.app_info.supported_platforms | join(sep=", ") }}</span>
      {% endif %}
    </div>
  </div>
  <div class="score-panel">
    <div class="grade grade-{{ report.grade | lower }}">{{ report.grade }}</div>
    <div class="score-num">{{ report.security_score }}<span>/100</span></div>
    <div class="score-bar"><div class="score-fill" style="width:{{ report.security_score }}%"></div></div>
  </div>
</div>
</div>
</div>

<main class="container" id="main-content" style="padding-top:24px">

<!-- Stats bar -->
<div class="stats-bar">
  <div class="stat"><span class="stat-val high">{{ high_count }}</span><span class="stat-label">High</span></div>
  <div class="stat"><span class="stat-val warn">{{ warn_count }}</span><span class="stat-label">Warning</span></div>
  <div class="stat"><span class="stat-val info">{{ info_count }}</span><span class="stat-label">Info</span></div>
  <div class="stat"><span class="stat-val {% if report.trackers | length > 0 %}warn{% else %}ok{% endif %}">{{ report.trackers | length }}</span><span class="stat-label">Trackers</span></div>
  <div class="stat"><span class="stat-val warn">{{ report.secrets | length }}</span><span class="stat-label">Secrets</span></div>
  <div class="stat"><span class="stat-val info">{{ report.scan_duration_ms }}ms</span><span class="stat-label">Scan Time</span></div>
</div>

<!-- Baseline Diff (shown only when --baseline was used) -->
{% if report.baseline_diff %}
<div class="section">
  <div class="section-title">Changes vs Baseline</div>
  <div class="section-body">
    <div class="diff-cards">
      <div class="diff-card">
        <span class="diff-val {% if report.baseline_diff.score_delta > 0 %}clr-ok{% elif report.baseline_diff.score_delta < 0 %}clr-bad{% else %}clr-dim{% endif %}">
          {% if report.baseline_diff.score_delta > 0 %}+{% endif %}{{ report.baseline_diff.score_delta }}
        </span>
        <span class="diff-label">Score Delta</span>
      </div>
      <div class="diff-card">
        <span class="diff-val {% if report.baseline_diff.new_findings | length > 0 %}clr-bad{% else %}clr-ok{% endif %}">{{ report.baseline_diff.new_findings | length }}</span>
        <span class="diff-label">New Findings</span>
      </div>
      <div class="diff-card">
        <span class="diff-val clr-ok">{{ report.baseline_diff.fixed_findings | length }}</span>
        <span class="diff-label">Fixed Findings</span>
      </div>
      <div class="diff-card">
        <span class="diff-val {% if report.baseline_diff.new_secrets > 0 %}clr-bad{% else %}clr-ok{% endif %}">{{ report.baseline_diff.new_secrets }}</span>
        <span class="diff-label">New Secrets</span>
      </div>
      <div class="diff-card">
        <span class="diff-val clr-ok">{{ report.baseline_diff.fixed_secrets }}</span>
        <span class="diff-label">Fixed Secrets</span>
      </div>
    </div>
    {% if report.baseline_diff.new_findings %}
    <div style="padding:8px 16px;background:var(--surface);border-top:1px solid var(--border);font-size:11px;color:var(--text-dim);text-transform:uppercase;letter-spacing:.04em">New Findings</div>
    <div class="diff-tags">
      {% for id in report.baseline_diff.new_findings %}<span class="diff-tag-new">{{ id }}</span>{% endfor %}
    </div>
    {% endif %}
    {% if report.baseline_diff.fixed_findings %}
    <div style="padding:8px 16px;background:var(--surface);border-top:1px solid var(--border);font-size:11px;color:var(--text-dim);text-transform:uppercase;letter-spacing:.04em">Fixed Findings</div>
    <div class="diff-tags">
      {% for id in report.baseline_diff.fixed_findings %}<span class="diff-tag-fixed">{{ id }}</span>{% endfor %}
    </div>
    {% endif %}
  </div>
</div>
{% endif %}

<!-- App Info -->
<div class="section">
  <div class="section-title">App Information</div>
  <div class="section-body">
    <table class="info-table">
      <tr><th scope="row">Bundle Name</th><td>{{ report.app_info.name }}</td></tr>
      <tr><th scope="row">Bundle ID</th><td>{{ report.app_info.identifier }}</td></tr>
      <tr><th scope="row">Version</th><td>{{ report.app_info.version }} ({{ report.app_info.build }})</td></tr>
      <tr><th scope="row">Platform</th><td>{{ report.app_info.platform }}</td></tr>
      <tr><th scope="row">Min OS Version</th><td>{{ report.app_info.min_os_version }}</td></tr>
      {% if report.app_info.sdk_name %}<tr><th scope="row">SDK</th><td>{{ report.app_info.sdk_name }}</td></tr>{% endif %}
      <tr><th scope="row">App Type</th><td>{{ report.app_info.app_type }}</td></tr>
      <tr><th scope="row">MD5</th><td style="font-family:var(--mono);font-size:12px">{{ report.file_hashes.md5 }}</td></tr>
      <tr><th scope="row">SHA1</th><td style="font-family:var(--mono);font-size:12px">{{ report.file_hashes.sha1 }}</td></tr>
      <tr><th scope="row">SHA256</th><td style="font-family:var(--mono);font-size:12px">{{ report.file_hashes.sha256 }}</td></tr>
      <tr><th scope="row">File Size</th><td>{{ report.file_hashes.size_bytes }} bytes</td></tr>
    </table>
  </div>
</div>

<!-- OWASP Mobile Top 10 Summary -->
<div class="section">
  <div class="section-title">OWASP Mobile Top 10</div>
  <div class="section-body">
    <div class="owasp-grid">
      {% for item in owasp_labels %}
      {% set mkey = item[0] %}
      {% set findings_list = report.owasp_summary | get(key=mkey) | default(value=[]) %}
      {% set count = findings_list | length %}
      <div class="owasp-cell {% if count > 0 %}bad{% else %}ok{% endif %}">
        <div class="owasp-code">{{ item[0] }}</div>
        <div class="owasp-label">{{ item[1] }}</div>
        <div class="owasp-count">{{ count }} finding{% if count != 1 %}s{% endif %}</div>
      </div>
      {% endfor %}
    </div>
  </div>
</div>

<!-- Binary Protections -->
{% if report.main_binary %}
<div class="section">
  <div class="section-title">Binary Protections — {{ report.main_binary.arch }}{% if report.main_binary.bits == 64 %}-64{% endif %}</div>
  <div class="section-body">
    <div class="protections-grid">
      {% for p in report.main_binary.protections %}
      <div class="protection-item" aria-label="{{ p.name }}: {% if p.enabled %}enabled{% elif p.severity == "high" %}disabled{% else %}warning{% endif %}">
        {% if p.enabled %}
        <div class="prot-icon ok" aria-hidden="true">✓</div>
        {% elif p.severity == "high" %}
        <div class="prot-icon bad" aria-hidden="true">✗</div>
        {% else %}
        <div class="prot-icon warn" aria-hidden="true">!</div>
        {% endif %}
        <div>
          <div class="prot-name">{{ p.name }}</div>
          <div class="prot-desc">{{ p.description }}</div>
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
</div>

{% if report.framework_binaries %}
<div class="section">
  <div class="section-title">Framework Binaries <span class="count">{{ report.framework_binaries | length }}</span></div>
  <div class="section-body">
    {% for fw in report.framework_binaries %}
    <details>
      <summary>Binary protections — {{ fw.path }} ({{ fw.arch }})</summary>
      <div class="protections-grid" style="border-top:1px solid var(--border-inner)">
        {% for p in fw.protections %}
        <div class="protection-item" aria-label="{{ p.name }}: {% if p.enabled %}enabled{% elif p.severity == "high" %}disabled{% else %}warning{% endif %}">
          {% if p.enabled %}<div class="prot-icon ok" aria-hidden="true">✓</div>
          {% elif p.severity == "high" %}<div class="prot-icon bad" aria-hidden="true">✗</div>
          {% else %}<div class="prot-icon warn" aria-hidden="true">!</div>{% endif %}
          <div>
            <div class="prot-name">{{ p.name }}</div>
            <div class="prot-desc">{{ p.description }}</div>
          </div>
        </div>
        {% endfor %}
      </div>
    </details>
    {% endfor %}
  </div>
</div>
{% endif %}
{% endif %}

<!-- Findings -->
<div class="section">
  <div class="section-title">Security Findings <span class="count">{{ report.findings | length }}</span></div>
  <div class="section-body">
    {% if report.findings %}
    <ul role="list" style="list-style:none;margin:0;padding:0">
    {% for f in report.findings %}
    <li role="listitem">
    <div class="finding">
      <div class="finding-header">
        <div>
          <div class="finding-title">{{ f.title }}</div>
          <div style="margin-top:4px">
            {% if f.severity == "high" %}<span class="sev-badge sev-high">High</span>
            {% elif f.severity == "warning" %}<span class="sev-badge sev-warn">Warning</span>
            {% elif f.severity == "info" %}<span class="sev-badge sev-info">Info</span>
            {% else %}<span class="sev-badge sev-secure">Secure</span>{% endif %}
            <span style="margin-left:8px;font-size:12px;color:var(--accent)">{{ f.category }}</span>
          </div>
        </div>
        <div class="finding-id">{{ f.id }}</div>
      </div>
      <div class="finding-desc">{{ f.description }}</div>
      {% if f.evidence %}
      <div class="finding-evidence">{{ f.evidence | first }}</div>
      {% endif %}
      {% if f.remediation %}
      <div class="finding-remediation">
        <div class="finding-remediation-label">Fix</div>
        <div class="finding-remediation-text">{{ f.remediation }}</div>
      </div>
      {% endif %}
      <div class="finding-meta">
        {% if f.cwe %}<span class="meta-tag">{{ f.cwe }}</span>{% endif %}
        {% if f.owasp_mobile %}<span class="meta-tag">OWASP {{ f.owasp_mobile }}</span>{% endif %}
        {% if f.owasp_masvs %}<span class="meta-tag">{{ f.owasp_masvs }}</span>{% endif %}
      </div>
    </div>
    </li>
    {% endfor %}
    </ul>
    {% else %}
    <div class="empty">No findings at the configured severity threshold.</div>
    {% endif %}
  </div>
</div>

<!-- Secrets -->
{% if report.secrets %}
<div class="section">
  <div class="section-title">Detected Secrets <span class="count">{{ report.secrets | length }}</span></div>
  <div class="section-body">
    {% for s in report.secrets %}
    <div class="secret-item">
      <div>
        {% if s.severity == "high" %}<div class="prot-icon bad" style="margin-top:2px">!</div>
        {% else %}<div class="prot-icon warn" style="margin-top:2px">!</div>{% endif %}
      </div>
      <div style="flex:1">
        <div style="display:flex;align-items:center;justify-content:space-between">
          <div class="secret-title">{{ s.title }}</div>
          {% if s.severity == "high" %}<span class="sev-badge sev-high">High</span>
          {% else %}<span class="sev-badge sev-warn">Warning</span>{% endif %}
        </div>
        {% if s.file_path %}<div class="secret-path">{{ s.file_path }}</div>{% endif %}
        <div class="secret-value">{{ s.matched_value | truncate(length=60) }}</div>
      </div>
    </div>
    {% endfor %}
  </div>
</div>
{% endif %}

<!-- Trackers -->
{% if report.trackers %}
<div class="section">
  <div class="section-title">Third-Party Trackers <span class="count">{{ report.trackers | length }}</span></div>
  <div class="section-body">
    {% for t in report.trackers %}
    <div class="tracker-item">
      <div>
        <div class="tracker-name">{{ t.name }}</div>
        <div class="tracker-evidence">{{ t.detection_evidence }}</div>
        <div class="tracker-cats">
          {% for cat in t.categories %}
          <span class="tracker-cat">{{ cat }}</span>
          {% endfor %}
        </div>
      </div>
      {% if t.website %}<a href="{{ t.website }}" target="_blank" rel="noopener" style="font-size:11px;white-space:nowrap">Website ↗</a>{% endif %}
    </div>
    {% endfor %}
  </div>
</div>
{% endif %}

<!-- Permissions -->
{% if report.app_info.permissions %}
<div class="section">
  <div class="section-title">Permissions <span class="count">{{ report.app_info.permissions | length }}</span></div>
  <div class="section-body">
    <table class="info-table">
      {% for p in report.app_info.permissions %}
      <tr>
        <th style="font-family:var(--mono);font-size:11px;font-weight:400;width:280px">{{ p.key }}</th>
        <td>
          {% if p.status == "dangerous" %}<span class="sev-badge sev-warn" style="margin-right:8px">Sensitive</span>{% endif %}
          <span style="color:var(--text-dim);font-size:12px">{{ p.description }}</span>
        </td>
      </tr>
      {% endfor %}
    </table>
  </div>
</div>
{% endif %}

<!-- Domains -->
{% if report.domains %}
<div class="section">
  <div class="section-title">Domains <span class="count">{{ report.domains | length }}</span></div>
  <div class="section-body">
    <div class="domain-list">
      {% for d in report.domains %}
      <span class="domain-tag" title="{{ d.context }}">{{ d.domain }}</span>
      {% endfor %}
    </div>
  </div>
</div>
{% endif %}

<!-- Emails -->
{% if report.emails %}
<div class="section">
  <div class="section-title">Emails <span class="count">{{ report.emails | length }}</span></div>
  <div class="section-body">
    <div class="domain-list">
      {% for email in report.emails %}
      <span class="email-tag">{{ email }}</span>
      {% endfor %}
    </div>
  </div>
</div>
{% endif %}

<!-- Domain Intelligence -->
{% if report.domain_intel %}
<div class="section">
  <div class="section-title">Domain Intelligence <span class="count">{{ report.domain_intel | length }}</span></div>
  <div class="section-body">
    <table class="info-table" style="background:var(--bg)">
      <thead>
        <tr style="border-bottom:1px solid var(--border)">
          <th scope="col" style="width:220px">Domain</th>
          <th scope="col" style="width:120px">IP</th>
          <th scope="col" style="width:160px">Location</th>
          <th scope="col" style="width:140px">Country</th>
          <th scope="col">ISP</th>
          <th scope="col" style="width:80px">OFAC</th>
        </tr>
      </thead>
      {% for d in report.domain_intel %}
      <tr {% if d.is_ofac_sanctioned %}style="background:var(--high-bg)"{% endif %}>
        <td style="font-family:var(--mono);font-size:12px">{{ d.domain }}</td>
        <td style="font-family:var(--mono);font-size:12px;color:var(--code-blue)">{{ d.ip | default(value="—") }}</td>
        <td style="font-size:12px;color:var(--text-dim)">{{ d.city | default(value="—") }}</td>
        <td style="font-size:12px">
          {% if d.country_code %}
          <span class="pill">{{ d.country_code }}</span>
          {{ d.country | default(value="") }}
          {% else %}—{% endif %}
        </td>
        <td style="font-size:12px;color:var(--text-dim)">{{ d.isp | default(value="—") }}</td>
        <td style="text-align:center">
          {% if d.is_ofac_sanctioned %}<span class="sev-badge sev-high">YES</span>
          {% else %}<span style="color:var(--text-dim);font-size:11px">—</span>{% endif %}
        </td>
      </tr>
      {% endfor %}
    </table>
  </div>
</div>
{% endif %}

<!-- Provisioning Profile -->
{% if report.provisioning %}
<div class="section">
  <div class="section-title">Provisioning Profile</div>
  <div class="section-body">
    <table class="info-table">
      {% if report.provisioning.name %}<tr><th scope="row">Profile Name</th><td>{{ report.provisioning.name }}</td></tr>{% endif %}
      {% if report.provisioning.team_name %}<tr><th scope="row">Team</th><td>{{ report.provisioning.team_name }}{% if report.provisioning.team_id %} <span class="pill">{{ report.provisioning.team_id }}</span>{% endif %}</td></tr>{% endif %}
      <tr><th scope="row">Profile Type</th><td>
        {% if report.provisioning.profile_type == "development" or report.provisioning.profile_type == "ad-hoc" %}
        <span class="sev-badge sev-warn">{{ report.provisioning.profile_type }}</span>
        {% elif report.provisioning.profile_type == "enterprise" %}
        <span class="sev-badge sev-high">enterprise</span>
        {% else %}
        <span class="sev-badge sev-secure">{{ report.provisioning.profile_type }}</span>
        {% endif %}
      </td></tr>
      {% if report.provisioning.expiration_date %}<tr><th scope="row">Expiration</th><td style="font-family:var(--mono);font-size:12px">{{ report.provisioning.expiration_date }}</td></tr>{% endif %}
      {% if report.provisioning.provisioned_device_count > 0 %}<tr><th scope="row">Provisioned Devices</th><td>{{ report.provisioning.provisioned_device_count }}</td></tr>{% endif %}
    </table>
  </div>
</div>
{% endif %}

<!-- Framework Components (SCA) -->
{% if report.framework_components %}
<div class="section">
  <div class="section-title">Framework Components (SCA) <span class="count">{{ report.framework_components | length }}</span></div>
  <div class="section-body">
    <table class="info-table" style="background:var(--bg)">
      <thead>
        <tr style="border-bottom:1px solid var(--border)">
          <th scope="col" style="width:200px">Framework</th>
          <th scope="col">Bundle ID</th>
          <th scope="col" style="width:120px">Version</th>
        </tr>
      </thead>
      {% for c in report.framework_components %}
      <tr>
        <td style="font-weight:500;color:var(--text-heading)">{{ c.name }}</td>
        <td style="font-family:var(--mono);font-size:12px;color:var(--code-blue)">{{ c.bundle_id | default(value="—") }}</td>
        <td style="font-family:var(--mono);font-size:12px">
          {% if c.version %}<span class="pill">{{ c.version }}</span>{% else %}<span style="color:var(--text-dim)">—</span>{% endif %}
        </td>
      </tr>
      {% endfor %}
    </table>
  </div>
</div>
{% endif %}

<!-- CVE Findings -->
{% if cve_findings %}
<div class="section">
  <div class="section-title">Known Vulnerable Dependencies (CVE) <span class="count">{{ cve_findings | length }}</span></div>
  <div class="section-body">
    <table class="info-table" style="background:var(--bg)">
      <thead>
        <tr style="border-bottom:1px solid var(--border)">
          <th scope="col" style="width:200px">Framework</th>
          <th scope="col" style="width:120px">CVE</th>
          <th scope="col" style="width:80px">Severity</th>
          <th scope="col">Title / Description</th>
        </tr>
      </thead>
      {% for f in cve_findings %}
      <tr class="{% if f.severity == 'high' %}cve-row-high{% else %}cve-row-warning{% endif %}">
        <td style="font-family:var(--mono);font-size:12px;color:var(--code-blue)">{{ f.evidence | first | default(value="—") }}</td>
        <td style="font-family:var(--mono);font-size:12px;white-space:nowrap">
          {% set cve_id = f.id | replace(from="QS-CVE-", to="") %}
          <a href="https://nvd.nist.gov/vuln/detail/{{ cve_id }}" target="_blank" rel="noopener">{{ cve_id }}</a>
        </td>
        <td>
          {% if f.severity == "high" %}<span class="sev-badge sev-high">High</span>
          {% else %}<span class="sev-badge sev-warn">Warning</span>{% endif %}
        </td>
        <td>
          <div style="font-size:13px;font-weight:500;color:var(--text-heading);margin-bottom:3px">{{ f.title }}</div>
          <div style="font-size:12px;color:var(--text-dim)">{{ f.description }}</div>
          {% if f.remediation %}<div style="font-size:11px;color:var(--secure);margin-top:4px">{{ f.remediation }}</div>{% endif %}
        </td>
      </tr>
      {% endfor %}
    </table>
  </div>
</div>
{% endif %}

<!-- Firebase -->
{% if report.firebase %}
<div class="section">
  <div class="section-title">Firebase Configuration</div>
  <div class="section-body">
    <div class="firebase-grid">
      {% if report.firebase.project_id %}<div class="firebase-item"><div class="firebase-key">Project ID</div><div class="firebase-val">{{ report.firebase.project_id }}</div></div>{% endif %}
      {% if report.firebase.database_url %}<div class="firebase-item"><div class="firebase-key">Database URL</div><div class="firebase-val">{{ report.firebase.database_url }}</div></div>{% endif %}
      {% if report.firebase.api_key %}<div class="firebase-item"><div class="firebase-key">API Key</div><div class="firebase-val">{{ report.firebase.api_key }}</div></div>{% endif %}
      {% if report.firebase.bundle_id %}<div class="firebase-item"><div class="firebase-key">Bundle ID</div><div class="firebase-val">{{ report.firebase.bundle_id }}</div></div>{% endif %}
      {% if report.firebase.google_app_id %}<div class="firebase-item"><div class="firebase-key">Google App ID</div><div class="firebase-val">{{ report.firebase.google_app_id }}</div></div>{% endif %}
    </div>
  </div>
</div>
{% endif %}

<!-- Audit Log -->
{% if report.scan_log %}
<div class="section">
  <div class="section-title">Scan Audit Log <span class="count">{{ report.scan_log | length }} steps</span></div>
  <div class="section-body" style="background:var(--bg);padding:12px 16px">
    <table style="width:100%;border-collapse:collapse">
      {% for entry in report.scan_log %}
      <tr>
        <td style="font-family:var(--mono);font-size:11px;color:var(--text-dim);white-space:nowrap;padding:2px 12px 2px 0;width:70px">{{ entry.elapsed_ms }}ms</td>
        <td style="font-size:12px;color:var(--text-body);padding:2px 0">{{ entry.step }}</td>
      </tr>
      {% endfor %}
    </table>
  </div>
</div>
{% endif %}

<div class="footer">
  <div><span class="footer-logo">Pavise</span> v{{ version }} — Fast Mobile App Static Analysis</div>
  <div>Scan completed in {{ report.scan_duration_ms }}ms</div>
</div>

</main><!-- /container -->
<script data-goatcounter="https://stats.pavise.app/count"
        async src="//stats.pavise.app/count.js"></script>
</body>
</html>
